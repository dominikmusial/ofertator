# PostgreSQL
POSTGRES_DB=allegro_bot
POSTGRES_USER=user
POSTGRES_PASSWORD=password  # Zmień na własne, bezpieczne hasło
DATABASE_URL=postgresql://user:password@db:5432/allegro_bot

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password
MINIO_URL=http://minio:9000
MINIO_INTERNAL_URL=http://host.docker.internal:9000
MINIO_PUBLIC_URL=https://ofertator.vautomate.pl/minio

# Allegro API
ALLEGRO_CLIENT_ID=TWOJ_CLIENT_ID
ALLEGRO_CLIENT_SECRET=TWOJ_CLIENT_SECRET

# Anthropic
ANTHROPIC_API_KEY="sk-ant-api03-..."

# NGROK
NGROK_AUTHTOKEN=AUTHTOKEN

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@vsprint.pl

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Default Admin
DEFAULT_ADMIN_EMAIL=admin@vsprint.pl
DEFAULT_ADMIN_PASSWORD=ChangeMeOnFirstLogin123!

# Vite
VITE_GOOGLE_CLIENT_ID=VITE_CLIENT_ID

# Environment Settings
ENVIRONMENT=development
DEBUG=true

# Asystenciai Integration - IMPORTANT: Use strong secret in production
ASYSTENCIAI_SHARED_SECRET=change-me-in-production-to-strong-secret
ASYSTENCIAI_SETUP_TOKEN_EXPIRE_MINUTES=30

# Google Gemini API - AI Features (for Asystenci AI users)
GEMINI_API_KEY=GEMINI_API_KEY