# Production Environment Variables for Bot-Sok Client (Eurohit)
# Copy this file to .env.client.prod and fill in your actual values

# PostgreSQL - Production Database for Client
POSTGRES_DB=allegro_bot_client_prod
POSTGRES_USER=allegro_bot_client_user
POSTGRES_PASSWORD=your_secure_client_password_here_change_this
DATABASE_URL=postgresql://allegro_bot_client_user:your_secure_client_password_here_change_this@db-client:5432/allegro_bot_client_prod

# Redis - Task Queue
CELERY_BROKER_URL=redis://redis-client:6379/0
CELERY_RESULT_BACKEND=redis://redis-client:6379/0

# MinIO - File Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_client_production
MINIO_URL=http://minio-client:9000
MINIO_INTERNAL_URL=http://minio-client:9000
MINIO_PUBLIC_URL=https://eurohit-ofertator.vautomate.pl/minio

# Allegro API - Optional (disabled for client via feature flags)
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# Anthropic API - Optional (client uses Gemini only by default)
ANTHROPIC_API_KEY=

# Google Gemini API - REQUIRED for AI Features (shared across all users)
GEMINI_API_KEY=your-production-gemini-key-here

# JWT Authentication - IMPORTANT: Use strong secrets in production
SECRET_KEY=your-very-long-and-secure-client-secret-key-change-this-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration - OPTIONAL (not used in client version by default)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@eurohit.com.pl
MAIL_USE_TLS=true

# Google OAuth - NOT USED (Google SSO disabled for client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Frontend URL - Production domain
FRONTEND_URL=https://eurohit-ofertator.vautomate.pl

# Client Admin Account - REQUIRED
# This is the main admin account that will be created automatically
CLIENT_ADMIN_EMAIL=admin@eurohit.com.pl
CLIENT_ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Legacy Default Admin (kept for compatibility, not used in client mode)
DEFAULT_ADMIN_EMAIL=admin@eurohit.com.pl
DEFAULT_ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Docker Hub Configuration (for GitHub Actions)
DOCKER_HUB_USERNAME=your_docker_hub_username

# Production Environment Settings
ENVIRONMENT=production
DEBUG=false

# Asystenciai Integration - Optional
ASYSTENCIAI_SHARED_SECRET=change-me-in-production-to-strong-secret
ASYSTENCIAI_SETUP_TOKEN_EXPIRE_MINUTES=30

# IMPORTANT NOTES:
# 1. GEMINI_API_KEY is REQUIRED - this is the shared AI key for all users
# 2. CLIENT_ADMIN_EMAIL and CLIENT_ADMIN_PASSWORD are REQUIRED
# 3. Google SSO is disabled - no need for GOOGLE_CLIENT_ID
# 4. Email is optional - user creation works without SMTP
# 5. Allegro is disabled via feature flags but fields kept for compatibility
