# Production Environment Variables for Bot-Sok
# Copy this file to .env and fill in your actual values

# PostgreSQL - Production Database
POSTGRES_DB=allegro_bot_prod
POSTGRES_USER=allegro_bot_user
POSTGRES_PASSWORD=your_secure_production_password_here
DATABASE_URL=postgresql://allegro_bot_user:your_secure_production_password_here@db:5432/allegro_bot_prod

# Redis - Task Queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MinIO - File Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here_production
MINIO_URL=http://minio:9000

# Allegro API - Required for your application
ALLEGRO_CLIENT_ID=your_production_allegro_client_id
ALLEGRO_CLIENT_SECRET=your_production_allegro_client_secret

# Anthropic API - AI Features (for vSprint employees)
ANTHROPIC_API_KEY=sk-ant-api03-your-production-key-here

# Google Gemini API - AI Features (for Asystenci AI users)
GEMINI_API_KEY=your-production-gemini-key-here

# NGROK - Not needed in production, but keeping for compatibility
NGROK_AUTHTOKEN=not_needed_in_production

# JWT Authentication - IMPORTANT: Use strong secrets in production
SECRET_KEY=your-very-long-and-secure-production-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration - Production SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_USERNAME=your-production-email@domain.com
MAIL_PASSWORD=your-production-app-password
MAIL_FROM=noreply@vsprint.pl

# Google OAuth - Production OAuth credentials
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_REDIRECT_URI=http://YOUR_VM_IP/auth/google/callback

# Frontend URL - Will be your VM's IP
FRONTEND_URL=http://YOUR_VM_IP

# Default Admin - Production admin account
DEFAULT_ADMIN_EMAIL=admin@vsprint.pl
DEFAULT_ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Vite - Frontend build (not used in production, but keeping for compatibility)
VITE_GOOGLE_CLIENT_ID=your-production-google-client-id

# Docker Hub Configuration (for GitHub Actions)
DOCKER_HUB_USERNAME=your_docker_hub_username

# Production Environment Settings
ENVIRONMENT=production
DEBUG=false 
# Internal URL for Docker communication
MINIO_INTERNAL_URL=http://minio:9000
# Public URL for external access (via nginx proxy)
MINIO_PUBLIC_URL=https://ofertator.vautomate.pl/minio

# Asystenciai Integration - IMPORTANT: Use strong secret in production
ASYSTENCIAI_SHARED_SECRET=change-me-in-production-to-strong-secret
ASYSTENCIAI_SETUP_TOKEN_EXPIRE_MINUTES=30
